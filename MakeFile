# Compiler and flags
CC = gcc
CFLAGS = -Wall -Wextra -g  # Enables warnings and debugging info

# Target executable
TARGET = my_program

# Source and object files
SRC = main.c socket_utils.c
OBJ = $(SRC:.c=.o)

# Build the target
$(TARGET): $(OBJ)
	$(CC) $(CFLAGS) -o $(TARGET) $(OBJ)

# Rule to build .o files from .c files
%.o: %.c
	$(CC) $(CFLAGS) -c $< -o $@

# Clean up generated files
clean:
	rm -f $(OBJ) $(TARGET)
